# ============================================================
# 🦊 FOXY PANEL — Environment Variables
# ============================================================

# ─── REQUIRED ────────────────────────────────────────────────
# Your WhatsApp session string.
# Run the full bot (Webfoxy) locally, send .getsession, paste here.
SESSION_ID=

# GitHub Personal Access Token to load commands from FoxySource.
# Must have repo read access.
GITHUB_PAT=

# ─── BOT IDENTITY ────────────────────────────────────────────
BOT_NAME=FOXY BOT
PREFIX=.
OWNER_NUMBER=

# ─── BOT BEHAVIOUR ───────────────────────────────────────────
BOT_MODE=public
AUTO_READ_STATUS=false
